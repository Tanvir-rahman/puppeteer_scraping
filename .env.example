# Copy to .env and fill in. .env is gitignored — never commit real creds.
# CLI flags override these (see cli.js:49-51); env keeps the password out of
# shell history and `ps`.

# Facebook login (required for first login; ignored once cookies.json exists)
FB_USER="you@example.com"
FB_PASS="yourpassword"

# Authenticator secret for auto 2FA (optional). Base32 string FB showed when you
# added the account to Google Authenticator/Authy. Spaces/dashes are stripped.
# FB Settings → Password and security → Two-factor auth → Authenticator app.
FB_TOTP="JBSW Y3DP EHPK 3PXP"

# Persistent browser profile dir (optional, RECOMMENDED). Log in by hand once into
# this profile, then FB stops challenging with reCAPTCHA. Gitignored — it holds a
# live session, treat like a password.
# FB_PROFILE="./fb-profile"

# Debug dir for login screenshots (optional). Set it and checkpoints.js dumps a
# PNG + page title/url at each login step — your eyes into a headless browser.
# PPT_DEBUG_DIR="./debug"
